@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix ex:   <http://example.org/survey-prov#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .

########################
# Agents
########################
ex:Laura a prov:Person, foaf:Person ;
    foaf:name "Laura" .

ex:Jack a prov:Person, foaf:Person ;
    foaf:name "Jack" .

ex:Jill a prov:Person, foaf:Person ;
    foaf:name "Jill" .

ex:Peter a prov:Person, foaf:Person ;
    foaf:name "Peter" .

ex:Paula a prov:Person, foaf:Person ;
    foaf:name "Paula" .

ex:Zack a prov:Person, foaf:Person ;
    foaf:name "Zack" .

########################
# Entities
########################
ex:survey_v1 a prov:Entity, prov:Plan ;
    prov:label "Initial survey on student financial support" .

ex:survey_v2 a prov:Entity, prov:Plan ;
    prov:label "Revised survey on student financial support" ;
    prov:wasDerivedFrom ex:survey_v1 .

ex:data_JJ a prov:Entity ;
    prov:label "Data collected by Jack and Jill (survey v1)" .

ex:data_PP a prov:Entity ;
    prov:label "Data collected by Peter and Paula (survey v2)" .

ex:all_data a prov:Entity ;
    prov:label "Merged survey dataset (JJ + PP)" ;
    prov:wasDerivedFrom ex:data_JJ, ex:data_PP .

ex:stats_pkg a prov:Entity ;
    prov:label "Statistics package used for analysis" .

ex:paper a prov:Entity ;
    prov:label "Published paper on student financial support survey" ;
    prov:wasDerivedFrom ex:all_data .

########################
# Activities
########################
ex:design_v1 a prov:Activity ;
    prov:label "Design initial survey" ;
    prov:wasAssociatedWith ex:Laura ;
    prov:generated ex:survey_v1 .

ex:collect_JJ a prov:Activity ;
    prov:label "Jack and Jill conduct survey and collect data" ;
    prov:wasAssociatedWith ex:Jack, ex:Jill ;
    prov:used ex:survey_v1 ;
    prov:generated ex:data_JJ .

ex:revise_survey a prov:Activity ;
    prov:label "Laura revises the survey one year later" ;
    prov:wasAssociatedWith ex:Laura ;
    prov:used ex:survey_v1 ;
    prov:generated ex:survey_v2 .

ex:collect_PP a prov:Activity ;
    prov:label "Peter and Paula conduct revised survey and collect data" ;
    prov:wasAssociatedWith ex:Peter, ex:Paula ;
    prov:used ex:survey_v2 ;
    prov:generated ex:data_PP .

ex:merge_data a prov:Activity ;
    prov:label "Zack merges all survey data" ;
    prov:wasAssociatedWith ex:Zack ;
    prov:used ex:data_JJ, ex:data_PP ;
    prov:generated ex:all_data .

ex:analyze_data a prov:Activity ;
    prov:label "Zack analyzes merged data with statistics package" ;
    prov:wasAssociatedWith ex:Zack ;
    prov:used ex:all_data, ex:stats_pkg .

ex:write_paper a prov:Activity ;
    prov:label "Write and publish survey results paper" ;
    prov:wasAssociatedWith ex:Laura, ex:Zack ;
    prov:used ex:all_data ;
    prov:generated ex:paper .

